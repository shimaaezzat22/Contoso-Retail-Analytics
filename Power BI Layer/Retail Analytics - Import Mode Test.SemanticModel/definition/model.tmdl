model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_ProTooling = ["DevMode"]

annotation PBI_QueryOrder = ["dim vAcquisitionChannel","dim vChannel","dim vCurrency","dim vCustomer","dim vDate","dim vEmployee","dim vPaymentMethod","dim vProduct","dim vPromotion","dim vReturnReason","dim vStore"]

ref table 'dim vAcquisitionChannel'
ref table 'dim vChannel'
ref table 'dim vCurrency'
ref table 'dim vCustomer'
ref table 'dim vDate'
ref table 'dim vEmployee'
ref table 'dim vPaymentMethod'
ref table 'dim vProduct'
ref table 'dim vPromotion'
ref table 'dim vReturnReason'
ref table 'dim vStore'

ref cultureInfo en-US

